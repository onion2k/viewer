{
  "name": "viewer",
  "version": "1.0.2",
  "private": true,
  "description": "Simple local image viewer desktop app",
  "author": "Christopher Neale",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --mac dmg --publish never",
    "dist:mac": "electron-builder --mac dmg --publish never",
    "dist:win": "electron-builder --win nsis --publish never",
    "release": "electron-builder --mac dmg --publish always",
    "release:mac": "electron-builder --mac dmg --publish always",
    "release:win": "electron-builder --win nsis --publish always"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.christopherneale.viewer",
    "productName": "Viewer",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "asar": true,
    "compression": "maximum",
    "electronLanguages": [
      "en"
    ],
    "mac": {
      "icon": "build/icon-bg.icns",
      "category": "public.app-category.photography",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "onion2k",
        "repo": "viewer"
      }
    ]
  },
  "dependencies": {
    "exifr": "^7.1.3"
  }
}
